# Copy to .env and fill in. Never commit .env.

# --- LLM provider ---
# "ollama" (Ollama Cloud, default) or "openai"
LLM_PROVIDER=ollama

# --- Ollama Cloud (primary) ---
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b

# --- OpenAI (fallback) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6

# --- PostgreSQL + PostGIS ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sgw
POSTGRES_USER=sgw
POSTGRES_PASSWORD=sgw_dev_only
# DATABASE_URL is derived from POSTGRES_* in docker-compose; override here for local (non-docker) dev
DATABASE_URL=postgresql+asyncpg://sgw:sgw_dev_only@localhost:5432/sgw

# --- Logging ---
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json            # json | console

# --- NOAA caches ---
NOAA_CACHE_DIR=./data/cache/noaa
NOAA_COOPS_STATION_PRIMARY=8665530   # Charleston Harbor
NOAA_COOPS_STATION_INLAND=8720030    # placeholder — pick per footprint

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173

# --- Frontend (VITE_ prefix — safe to expose to browser) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_ATTRIBUTION=© OpenStreetMap contributors

# --- Feature flags ---
FEATURE_LLM_ENABLED=true
FEATURE_OBSERVABILITY_STACK=false   # set true to enable Prometheus/Grafana profile
